10 REM ** CONWAY'S GAME OF LIFE **
20 REM CELLULAR AUTOMATON ON 20X20 GRID
30 PRINT "** GAME OF LIFE **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 140
80 PRINT
90 PRINT "CELLS LIVE OR DIE BY RULES:"
100 PRINT " 2-3 NEIGHBORS: SURVIVES"
110 PRINT " 3 NEIGHBORS: BIRTH"
120 PRINT " ELSE: DIES"
130 PRINT "ENTER CELLS, THEN WATCH!"
140 PRINT
150 DIM A(22,22)
160 DIM B(22,22)
170 REM ** CLEAR GRID **
180 FOR I = 0 TO 21
190 FOR J = 0 TO 21
200 LET A(I,J) = 0
210 LET B(I,J) = 0
220 NEXT J
230 NEXT I
240 REM ** INPUT CELLS **
250 PRINT "ENTER LIVE CELLS (ROW,COL)"
260 PRINT "ROW 1-20, COL 1-20"
270 PRINT "ENTER 0,0 WHEN DONE"
280 PRINT "ROW,COL";
290 INPUT R,C
300 IF R = 0 THEN GOTO 340
310 IF R < 1 THEN GOTO 280
320 IF R > 20 THEN GOTO 280
325 IF C < 1 THEN GOTO 280
330 IF C > 20 THEN GOTO 280
335 LET A(R,C) = 1
336 GOTO 280
340 PRINT "HOW MANY GENERATIONS";
350 INPUT G
360 REM ** DISPLAY GRID **
370 PRINT
380 FOR I = 1 TO 20
390 LET L$ = ""
400 FOR J = 1 TO 20
410 IF A(I,J) = 1 THEN LET L$ = L$ + "*"
420 IF A(I,J) = 0 THEN LET L$ = L$ + "."
430 NEXT J
440 PRINT L$
450 NEXT I
460 LET G = G - 1
470 IF G < 0 THEN GOTO 620
480 REM ** COMPUTE NEXT GEN **
490 FOR I = 1 TO 20
500 FOR J = 1 TO 20
510 LET N = A(I-1,J-1)+A(I-1,J)+A(I-1,J+1)
520 LET N = N+A(I,J-1)+A(I,J+1)
530 LET N = N+A(I+1,J-1)+A(I+1,J)+A(I+1,J+1)
540 LET B(I,J) = 0
550 IF A(I,J) = 1 THEN IF N = 2 THEN LET B(I,J) = 1
560 IF N = 3 THEN LET B(I,J) = 1
570 NEXT J
580 NEXT I
590 REM ** COPY B TO A **
600 FOR I = 1 TO 20
610 FOR J = 1 TO 20
615 LET A(I,J) = B(I,J)
616 NEXT J
617 NEXT I
618 GOTO 370
620 PRINT
630 PRINT "DONE. PLAY AGAIN? (1=YES, 0=NO)";
640 INPUT Q
650 IF Q = 1 THEN GOTO 170
660 END
