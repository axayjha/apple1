10 REM ** FIBONACCI SEQUENCE **
20 REM PRINTS FIRST 20 FIBONACCI NUMBERS
30 REM USES INTEGER ARITHMETIC (16-BIT)
40 PRINT "** FIBONACCI NUMBERS **"
50 PRINT
60 LET A = 0
70 LET B = 1
80 FOR I = 1 TO 20
90 PRINT I;": ";A
100 LET C = A + B
110 LET A = B
120 LET B = C
130 NEXT I
140 PRINT
150 PRINT "DONE."
160 END
