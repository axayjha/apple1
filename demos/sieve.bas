10 REM ** SIEVE OF ERATOSTHENES **
20 REM FIND ALL PRIMES UP TO 100
30 PRINT "** SIEVE OF ERATOSTHENES **"
40 PRINT
50 DIM A(100)
60 REM INITIALIZE: 1=PRIME CANDIDATE
70 FOR I = 2 TO 100
80 LET A(I) = 1
90 NEXT I
100 REM SIEVE: MARK MULTIPLES
110 FOR I = 2 TO 10
120 IF A(I) = 0 THEN GOTO 170
130 LET J = I * I
140 IF J > 100 THEN GOTO 170
150 LET A(J) = 0
160 LET J = J + I
165 IF J <= 100 THEN GOTO 150
170 NEXT I
180 REM PRINT PRIMES
190 PRINT "PRIMES UP TO 100:"
200 PRINT
210 LET C = 0
220 FOR I = 2 TO 100
230 IF A(I) = 0 THEN GOTO 260
240 PRINT I;" ";
250 LET C = C + 1
260 NEXT I
270 PRINT
280 PRINT
290 PRINT C;" PRIMES FOUND."
300 END
