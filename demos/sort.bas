10 REM ** BUBBLE SORT DEMO **
20 REM SORTS 10 RANDOM NUMBERS
30 PRINT "** BUBBLE SORT DEMO **"
40 PRINT
50 DIM A(10)
60 REM FILL WITH RANDOM NUMBERS
70 PRINT "UNSORTED: ";
80 FOR I = 1 TO 10
90 LET A(I) = RND(99) + 1
100 PRINT A(I);" ";
110 NEXT I
120 PRINT
130 PRINT
140 REM BUBBLE SORT
150 PRINT "SORTING..."
160 FOR I = 1 TO 9
170 FOR J = 1 TO 10 - I
180 IF A(J) <= A(J + 1) THEN GOTO 220
190 LET T = A(J)
200 LET A(J) = A(J + 1)
210 LET A(J + 1) = T
220 NEXT J
230 NEXT I
240 REM PRINT RESULT
250 PRINT
260 PRINT "SORTED:   ";
270 FOR I = 1 TO 10
280 PRINT A(I);" ";
290 NEXT I
300 PRINT
310 PRINT
320 PRINT "AGAIN? (1=YES, 0=NO)";
330 INPUT A
340 IF A = 1 THEN GOTO 40
350 END
