10 REM ** STAR TREK **
20 REM DESTROY ALL KLINGONS IN 30 STARDATES
30 PRINT "** STAR TREK **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 160
80 PRINT
90 PRINT "DESTROY ALL KLINGONS IN 30 DATES!"
100 PRINT "COMMANDS:"
110 PRINT " SRS - SHORT RANGE SCAN"
120 PRINT " LRS - LONG RANGE SCAN"
130 PRINT " NAV - NAVIGATE (MOVE)"
140 PRINT " PHA - FIRE PHASERS"
150 PRINT " TOR - FIRE TORPEDO"
160 REM ** INIT GALAXY **
170 DIM G(4,4)
180 DIM K(4,4)
190 LET TK = 0
200 LET E = 3000
210 LET T = 30
220 LET QR = RND(4) + 1
230 LET QC = RND(4) + 1
240 LET SR = RND(8) + 1
250 LET SC = RND(8) + 1
260 REM ** POPULATE GALAXY **
270 FOR I = 1 TO 4
280 FOR J = 1 TO 4
290 LET K(I,J) = 0
300 IF RND(100) < 25 THEN LET K(I,J) = RND(3) + 1
310 LET TK = TK + K(I,J)
320 LET G(I,J) = K(I,J) * 100 + RND(5) * 10 + RND(4)
330 NEXT J
340 NEXT I
350 IF TK = 0 THEN LET K(1,1) = 2
355 IF TK = 0 THEN LET TK = 2
360 PRINT "MISSION: DESTROY";TK;"KLINGONS"
370 PRINT "ENERGY:";E;" STARDATES LEFT:";T
380 REM ** COMMAND LOOP **
390 PRINT
400 PRINT "COMMAND (SRS/LRS/NAV/PHA/TOR)";
410 INPUT A$
420 IF A$ = "SRS" THEN GOTO 500
430 IF A$ = "LRS" THEN GOTO 570
440 IF A$ = "NAV" THEN GOTO 630
450 IF A$ = "PHA" THEN GOTO 700
460 IF A$ = "TOR" THEN GOTO 760
470 PRINT "UNKNOWN COMMAND"
480 GOTO 390
490 REM ** SHORT RANGE SCAN **
500 PRINT "SECTOR [";QR;",";QC;"]"
510 PRINT "POSITION:";SR;",";SC
520 PRINT "ENERGY:";E
530 PRINT "KLINGONS HERE:";K(QR,QC)
540 PRINT "STARDATES LEFT:";T
550 GOTO 390
560 REM ** LONG RANGE SCAN **
570 PRINT "LONG RANGE SCAN:"
580 FOR I = 1 TO 4
590 FOR J = 1 TO 4
600 PRINT G(I,J);
610 NEXT J
620 PRINT
625 NEXT I
626 GOTO 390
630 REM ** NAVIGATE **
640 PRINT "QUADRANT ROW (1-4)";
650 INPUT NR
660 PRINT "QUADRANT COL (1-4)";
670 INPUT NC
680 IF NR < 1 THEN GOTO 390
685 IF NR > 4 THEN GOTO 390
686 IF NC < 1 THEN GOTO 390
687 IF NC > 4 THEN GOTO 390
688 LET QR = NR
689 LET QC = NC
690 LET E = E - 100
691 LET T = T - 1
692 IF T <= 0 THEN GOTO 850
693 IF E <= 0 THEN GOTO 870
694 PRINT "ARRIVED AT QUADRANT";QR;",";QC
695 GOTO 390
700 REM ** PHASERS **
710 IF K(QR,QC) = 0 THEN PRINT "NO TARGETS"
715 IF K(QR,QC) = 0 THEN GOTO 390
720 PRINT "ENERGY TO FIRE";
730 INPUT F
740 IF F > E THEN PRINT "NOT ENOUGH!"
745 IF F > E THEN GOTO 390
750 LET E = E - F
752 IF F > K(QR,QC) * 200 THEN GOTO 755
753 PRINT "KLINGON DAMAGED BUT ALIVE!"
754 GOTO 390
755 PRINT "KLINGON DESTROYED!"
756 LET TK = TK - 1
757 LET K(QR,QC) = K(QR,QC) - 1
758 IF TK = 0 THEN GOTO 830
759 GOTO 390
760 REM ** TORPEDO **
770 IF K(QR,QC) = 0 THEN PRINT "NO TARGETS"
775 IF K(QR,QC) = 0 THEN GOTO 390
780 LET E = E - 50
790 IF RND(100) < 60 THEN GOTO 810
800 PRINT "TORPEDO MISSED!"
805 GOTO 390
810 PRINT "*** DIRECT HIT! ***"
815 LET K(QR,QC) = K(QR,QC) - 1
820 LET TK = TK - 1
825 IF TK = 0 THEN GOTO 830
826 GOTO 390
830 PRINT
840 PRINT "*** CONGRATULATIONS! ***"
842 PRINT "ALL KLINGONS DESTROYED!"
844 GOTO 880
850 PRINT
860 PRINT "TIME'S UP! KLINGONS WIN!"
862 GOTO 880
870 PRINT "OUT OF ENERGY! STRANDED!"
880 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
890 INPUT Q
900 IF Q = 1 THEN GOTO 160
910 END
