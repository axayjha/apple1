10 REM ** NIM **
20 REM CLASSIC MATCHSTICK GAME
30 PRINT "** NIM **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 140
80 PRINT
90 PRINT "THERE ARE 21 STICKS."
100 PRINT "TAKE 1, 2, OR 3 EACH TURN."
110 PRINT "WHOEVER TAKES THE LAST STICK"
120 PRINT "LOSES! YOU GO FIRST."
130 PRINT
140 REM ** START GAME **
150 LET S = 21
160 PRINT
170 PRINT "STICKS REMAINING:";S
180 REM ** DRAW STICKS **
190 LET L$ = ""
200 FOR I = 1 TO S
210 LET L$ = L$ + "I"
220 NEXT I
230 PRINT L$
240 PRINT
250 REM ** PLAYER TURN **
260 PRINT "TAKE HOW MANY (1-3)";
270 INPUT P
280 IF P < 1 THEN PRINT "MUST TAKE AT LEAST 1!"
285 IF P < 1 THEN GOTO 260
290 IF P > 3 THEN PRINT "3 IS THE MAX!"
295 IF P > 3 THEN GOTO 260
300 IF P > S THEN PRINT "NOT THAT MANY LEFT!"
305 IF P > S THEN GOTO 260
310 LET S = S - P
320 IF S <= 0 THEN GOTO 430
330 PRINT "YOU TOOK";P;". LEFT:";S
340 REM ** COMPUTER TURN **
350 REM ** OPTIMAL: LEAVE MULTIPLE OF 4 + 1 **
360 LET C = S - 1
370 LET C = C - (C / 4) * 4
380 IF C = 0 THEN LET C = RND(3) + 1
390 IF C > S THEN LET C = S
400 LET S = S - C
410 PRINT "I TAKE";C;". LEFT:";S
420 IF S <= 0 THEN GOTO 450
425 GOTO 160
430 REM ** PLAYER TOOK LAST **
440 PRINT "YOU TOOK THE LAST STICK!"
442 PRINT "*** I WIN! ***"
444 GOTO 460
450 PRINT "I TOOK THE LAST STICK."
452 PRINT "*** YOU WIN! ***"
460 PRINT
470 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
480 INPUT Q
490 IF Q = 1 THEN GOTO 140
500 PRINT "THANKS FOR PLAYING!"
510 END
