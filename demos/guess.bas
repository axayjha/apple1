10 REM ** NUMBER GUESSING GAME **
20 REM COMPUTER PICKS 1-100, YOU GUESS
30 PRINT "** NUMBER GUESSING GAME **"
40 PRINT
50 PRINT "I'M THINKING OF A NUMBER"
60 PRINT "BETWEEN 1 AND 100."
70 PRINT
80 LET N = RND(100) + 1
90 LET T = 0
100 PRINT "YOUR GUESS";
110 INPUT G
120 LET T = T + 1
130 IF G = N THEN GOTO 180
140 IF G < N THEN PRINT "TOO LOW!"
150 IF G > N THEN PRINT "TOO HIGH!"
160 GOTO 100
170 REM ** WINNER **
180 PRINT
190 PRINT "CORRECT!"
200 PRINT "YOU GOT IT IN ";T;" TRIES."
210 PRINT
220 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
230 INPUT A
240 IF A = 1 THEN GOTO 40
250 PRINT "THANKS FOR PLAYING!"
260 END
