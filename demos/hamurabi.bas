10 REM ** HAMURABI **
20 REM RULE ANCIENT SUMERIA FOR 10 YEARS
30 PRINT "** HAMURABI **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 150
80 PRINT
90 PRINT "YOU GOVERN ANCIENT SUMERIA."
100 PRINT "BUY/SELL LAND, FEED YOUR PEOPLE,"
110 PRINT "AND PLANT CROPS EACH YEAR."
120 PRINT "SURVIVE 10 YEARS TO WIN!"
130 PRINT
140 REM ** INITIALIZE **
150 LET Y = 0
160 LET P = 100
170 LET S = 2800
180 LET A = 1000
190 LET D = 0
200 LET H = 3
210 LET E = 200
220 LET TD = 0
230 REM ** YEARLY REPORT **
240 LET Y = Y + 1
250 IF Y > 10 THEN GOTO 700
260 PRINT
270 PRINT "==== YEAR";Y;"===="
280 PRINT "POPULATION:";P
290 PRINT "ACRES:";A
300 PRINT "GRAIN IN STORE:";S
310 IF D > 0 THEN PRINT D;" PEOPLE STARVED"
320 LET L = RND(10) + 17
330 PRINT "LAND COSTS";L;" BUSHELS/ACRE"
340 REM ** BUY LAND **
350 PRINT "ACRES TO BUY";
360 INPUT B
370 IF B < 0 THEN GOTO 350
380 IF B * L > S THEN PRINT "NOT ENOUGH GRAIN!"
385 IF B * L > S THEN GOTO 350
390 LET A = A + B
400 LET S = S - B * L
410 IF B > 0 THEN GOTO 450
420 REM ** SELL LAND **
430 PRINT "ACRES TO SELL";
440 INPUT B
445 IF B < 0 THEN GOTO 430
446 IF B > A THEN PRINT "NOT ENOUGH LAND!"
447 IF B > A THEN GOTO 430
448 LET A = A - B
449 LET S = S + B * L
450 REM ** FEED PEOPLE **
460 PRINT "BUSHELS TO FEED PEOPLE";
470 INPUT F
480 IF F < 0 THEN GOTO 460
490 IF F > S THEN PRINT "NOT ENOUGH GRAIN!"
495 IF F > S THEN GOTO 460
500 LET S = S - F
510 REM ** PLANT CROPS **
520 PRINT "ACRES TO PLANT";
530 INPUT C
540 IF C < 0 THEN GOTO 520
550 IF C > A THEN PRINT "NOT ENOUGH LAND!"
555 IF C > A THEN GOTO 520
560 IF C > S * 2 THEN PRINT "NOT ENOUGH GRAIN!"
565 IF C > S * 2 THEN GOTO 520
570 IF C > P * 10 THEN PRINT "NOT ENOUGH PEOPLE!"
575 IF C > P * 10 THEN GOTO 520
580 LET S = S - C / 2
590 REM ** HARVEST **
600 LET H = RND(5) + 1
610 LET S = S + H * C
620 REM ** RATS **
630 IF RND(2) = 1 THEN LET E = S / (RND(3) + 3)
635 IF RND(2) = 1 THEN LET S = S - E
640 REM ** STARVATION **
650 LET D = P - F / 20
660 IF D < 0 THEN LET D = 0
670 LET TD = TD + D
680 LET P = P - D
690 IF P <= 0 THEN GOTO 770
695 REM ** IMMIGRANTS **
696 LET I = RND(5) + 1
697 LET P = P + I
698 REM ** PLAGUE **
699 IF RND(100) < 15 THEN LET P = P / 2
700 IF Y <= 10 THEN GOTO 240
710 REM ** FINAL REPORT **
720 PRINT
730 PRINT "==== FINAL REPORT ===="
740 PRINT "YOU RULED 10 YEARS."
750 PRINT "POPULATION:";P
760 PRINT "ACRES:";A;" GRAIN:";S
762 PRINT "TOTAL STARVED:";TD
764 IF TD < 30 THEN PRINT "SUPERB LEADERSHIP!"
766 IF TD > 30 THEN IF TD < 80 THEN PRINT "FAIR PERFORMANCE."
768 IF TD > 80 THEN PRINT "THE PEOPLE REVOLTED!"
769 GOTO 790
770 PRINT
780 PRINT "EVERYONE STARVED! YOU LOSE!"
790 PRINT
800 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
810 INPUT Q
820 IF Q = 1 THEN GOTO 150
830 END
