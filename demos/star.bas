10 REM ** STAR PATTERN **
20 REM DRAWS A DIAMOND OF STARS
30 PRINT "** STAR DIAMOND PATTERN **"
40 PRINT
50 LET S = 10
60 REM TOP HALF
70 FOR I = 1 TO S
80 FOR J = 1 TO S - I
90 PRINT " ";
100 NEXT J
110 FOR J = 1 TO 2 * I - 1
120 PRINT "*";
130 NEXT J
140 PRINT
150 NEXT I
160 REM BOTTOM HALF
170 FOR I = S - 1 TO 1 STEP -1
180 FOR J = 1 TO S - I
190 PRINT " ";
200 NEXT J
210 FOR J = 1 TO 2 * I - 1
220 PRINT "*";
230 NEXT J
240 PRINT
250 NEXT I
260 PRINT
270 PRINT "SIZE (1-12, 0=QUIT)";
280 INPUT S
290 IF S = 0 THEN GOTO 310
300 GOTO 60
310 END
