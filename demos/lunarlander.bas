10 REM ** LUNAR LANDER **
20 REM LAND YOUR SPACECRAFT SAFELY ON THE MOON
30 PRINT "** LUNAR LANDER **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 150
80 PRINT
90 PRINT "YOU ARE LANDING A SPACECRAFT ON"
100 PRINT "THE MOON. CONTROL YOUR THRUST"
110 PRINT "EACH SECOND (0-9). LAND WITH"
120 PRINT "VELOCITY UNDER 5 TO SURVIVE!"
130 PRINT "YOU HAVE 200 UNITS OF FUEL."
140 PRINT
150 REM ** INITIALIZE **
160 LET A = 500
170 LET V = 50
180 LET F = 200
190 LET T = 0
200 REM ** MAIN LOOP **
210 PRINT "-----------------------------"
220 PRINT "TIME:";T;" ALT:";A;" VEL:";V
230 PRINT "FUEL:";F
240 IF F = 0 THEN PRINT "*** NO FUEL! ***"
250 IF F = 0 THEN GOTO 310
260 PRINT "THRUST (0-9)";
270 INPUT B
280 IF B < 0 THEN LET B = 0
290 IF B > 9 THEN LET B = 9
300 IF B > F THEN LET B = F
310 REM ** PHYSICS **
320 LET V = V + 5 - B
330 LET A = A - V
340 LET F = F - B
350 LET T = T + 1
360 IF A > 0 THEN GOTO 200
370 REM ** LANDING CHECK **
380 LET A = 0
390 PRINT "-----------------------------"
400 PRINT "*** CONTACT! ***"
410 PRINT "VELOCITY AT IMPACT:";V
420 IF V < 5 THEN GOTO 460
430 PRINT "YOU CRASHED! TOO FAST!"
440 PRINT "BETTER LUCK NEXT TIME."
450 GOTO 490
460 PRINT "PERFECT LANDING!"
470 PRINT "CONGRATULATIONS!"
480 PRINT "TIME ELAPSED:";T;" SECONDS"
490 PRINT
500 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
510 INPUT Q
520 IF Q = 1 THEN GOTO 150
530 PRINT "GOODBYE, ASTRONAUT!"
540 END
