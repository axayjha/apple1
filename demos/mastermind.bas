10 REM ** MASTERMIND **
20 REM BULLS AND COWS - BREAK THE CODE
30 PRINT "** MASTERMIND **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 160
80 PRINT
90 PRINT "I HAVE PICKED 4 UNIQUE DIGITS"
100 PRINT "FROM 1-6. GUESS MY CODE!"
110 PRINT "BULLS = RIGHT DIGIT, RIGHT PLACE"
120 PRINT "COWS = RIGHT DIGIT, WRONG PLACE"
130 PRINT "YOU HAVE 10 GUESSES."
140 PRINT
150 REM ** GENERATE SECRET **
160 DIM S(4)
170 DIM G(4)
180 LET S(1) = RND(6) + 1
190 LET S(2) = RND(6) + 1
200 IF S(2) = S(1) THEN GOTO 190
210 LET S(3) = RND(6) + 1
220 IF S(3) = S(1) THEN GOTO 210
230 IF S(3) = S(2) THEN GOTO 210
240 LET S(4) = RND(6) + 1
250 IF S(4) = S(1) THEN GOTO 240
260 IF S(4) = S(2) THEN GOTO 240
270 IF S(4) = S(3) THEN GOTO 240
280 LET T = 0
290 REM ** GUESS LOOP **
300 LET T = T + 1
310 IF T > 10 THEN GOTO 600
320 PRINT
330 PRINT "GUESS #";T
340 PRINT "ENTER 4 DIGITS (1-6)"
350 PRINT "DIGIT 1";
360 INPUT G(1)
370 PRINT "DIGIT 2";
380 INPUT G(2)
390 PRINT "DIGIT 3";
400 INPUT G(3)
410 PRINT "DIGIT 4";
420 INPUT G(4)
430 REM ** COUNT BULLS **
440 LET B = 0
450 LET C = 0
460 FOR I = 1 TO 4
470 IF G(I) = S(I) THEN LET B = B + 1
480 NEXT I
490 REM ** COUNT COWS **
500 FOR I = 1 TO 4
510 FOR J = 1 TO 4
520 IF I = J THEN GOTO 550
530 IF G(I) = S(J) THEN LET C = C + 1
550 NEXT J
560 NEXT I
570 PRINT "BULLS:";B;" COWS:";C
580 IF B = 4 THEN GOTO 630
590 GOTO 300
600 REM ** LOST **
610 PRINT "OUT OF GUESSES!"
620 PRINT "CODE WAS:";S(1);S(2);S(3);S(4)
625 GOTO 650
630 PRINT
640 PRINT "*** YOU CRACKED THE CODE! ***"
645 PRINT "IN";T;"GUESSES!"
650 PRINT
660 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
670 INPUT Q
680 IF Q = 1 THEN GOTO 160
690 END
