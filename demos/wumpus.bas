10 REM ** HUNT THE WUMPUS **
20 REM CLASSIC CAVE GAME - GREGORY YOB 1972
30 PRINT "** HUNT THE WUMPUS **"
40 PRINT
50 PRINT "WANT INSTRUCTIONS? (1=YES, 0=NO)";
60 INPUT Q
70 IF Q = 0 THEN GOTO 170
80 PRINT
90 PRINT "A WUMPUS LIVES IN A CAVE OF 20"
100 PRINT "ROOMS. EACH CONNECTS TO 3 OTHERS."
110 PRINT "HAZARDS: 2 PITS, 2 BAT ROOMS."
120 PRINT "SENSES WARN YOU OF NEARBY DANGER."
130 PRINT "SHOOT ARROWS TO KILL THE WUMPUS!"
140 PRINT "COMMANDS: M=MOVE, S=SHOOT"
150 PRINT
160 REM ** CAVE MAP - DODECAHEDRON **
170 DIM C(20,3)
180 FOR I = 1 TO 20
190 READ C(I,1),C(I,2),C(I,3)
200 NEXT I
210 REM ** ADJACENCY DATA **
220 DATA 2,5,8,1,3,10,2,4,12,3,5,14,4,1,6
230 DATA 5,7,15,6,8,17,7,1,9,8,10,18,9,2,11
240 DATA 10,12,19,11,3,13,12,14,20,13,4,15,14,6,16
250 DATA 15,17,20,16,7,18,17,9,19,18,11,20,19,13,16
260 REM ** PLACE THINGS **
270 LET P = RND(20) + 1
280 LET W = RND(20) + 1
290 IF W = P THEN GOTO 280
300 LET B1 = RND(20) + 1
310 IF B1 = P THEN GOTO 300
320 IF B1 = W THEN GOTO 300
330 LET B2 = RND(20) + 1
340 IF B2 = P THEN GOTO 330
350 IF B2 = W THEN GOTO 330
360 IF B2 = B1 THEN GOTO 330
370 LET P1 = RND(20) + 1
380 IF P1 = P THEN GOTO 370
390 LET P2 = RND(20) + 1
400 IF P2 = P THEN GOTO 390
410 IF P2 = P1 THEN GOTO 390
420 LET A = 5
430 REM ** MAIN LOOP **
440 PRINT
450 PRINT "YOU ARE IN ROOM";P
460 PRINT "TUNNELS LEAD TO";C(P,1);C(P,2);C(P,3)
470 REM ** CHECK SENSES **
480 FOR I = 1 TO 3
490 LET R = C(P,I)
500 IF R = W THEN PRINT "I SMELL A WUMPUS!"
510 IF R = P1 THEN PRINT "I FEEL A DRAFT!"
520 IF R = P2 THEN PRINT "I FEEL A DRAFT!"
530 IF R = B1 THEN PRINT "BATS NEARBY!"
540 IF R = B2 THEN PRINT "BATS NEARBY!"
550 NEXT I
560 PRINT "SHOOT OR MOVE (S/M)";
570 INPUT A$
580 IF A$ = "M" THEN GOTO 630
590 IF A$ = "S" THEN GOTO 710
600 GOTO 560
610 REM ** MOVE **
630 PRINT "WHERE TO";
640 INPUT R
650 IF R = C(P,1) THEN GOTO 670
660 IF R = C(P,2) THEN GOTO 670
665 IF R = C(P,3) THEN GOTO 670
666 PRINT "NOT POSSIBLE!"
667 GOTO 630
670 LET P = R
680 IF P = W THEN GOTO 820
690 IF P = P1 THEN GOTO 840
695 IF P = P2 THEN GOTO 840
700 IF P = B1 THEN GOTO 860
705 IF P = B2 THEN GOTO 860
706 GOTO 440
710 REM ** SHOOT **
720 PRINT "SHOOT INTO WHICH ROOM";
730 INPUT R
740 LET A = A - 1
750 IF R = W THEN GOTO 800
760 PRINT "MISSED!"
770 LET W = C(W,RND(3)+1)
780 IF W = P THEN GOTO 820
790 IF A = 0 THEN GOTO 880
795 GOTO 440
800 PRINT "*** YOU GOT THE WUMPUS! ***"
810 GOTO 900
820 PRINT "THE WUMPUS GOT YOU!"
830 GOTO 900
840 PRINT "FELL IN A PIT! AAAA..."
850 GOTO 900
860 PRINT "ZAP! BAT CARRIES YOU AWAY!"
870 LET P = RND(20) + 1
875 GOTO 670
880 PRINT "OUT OF ARROWS! YOU LOSE."
900 PRINT
910 PRINT "PLAY AGAIN? (1=YES, 0=NO)";
920 INPUT Q
930 IF Q = 1 THEN GOTO 260
940 END
