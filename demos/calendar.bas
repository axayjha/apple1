10 REM ** CALENDAR PRINTER **
20 REM PRINTS MONTH CALENDAR
30 PRINT "** CALENDAR **"
40 PRINT
50 PRINT "MONTH (1-12)";
60 INPUT M
70 PRINT "YEAR";
80 INPUT Y
90 REM DAYS IN MONTH
100 DIM D(12)
110 LET D(1) = 31
120 LET D(2) = 28
130 LET D(3) = 31
140 LET D(4) = 30
150 LET D(5) = 31
160 LET D(6) = 30
170 LET D(7) = 31
180 LET D(8) = 31
190 LET D(9) = 30
200 LET D(10) = 31
210 LET D(11) = 30
220 LET D(12) = 31
230 REM LEAP YEAR CHECK
240 IF M <> 2 THEN GOTO 270
250 LET L = Y - (Y / 4) * 4
260 IF L = 0 THEN LET D(2) = 29
270 REM ZELLERS FORMULA FOR DAY OF WEEK
280 REM FIND WHAT DAY THE 1ST FALLS ON
290 LET A = (14 - M) / 12
300 LET B = Y - A
310 LET C = M + 12 * A - 2
320 LET W = (1 + B + B / 4 - B / 100 + B / 400 + (31 * C) / 12)
330 LET W = W - (W / 7) * 7
340 REM PRINT HEADER
350 PRINT
360 PRINT " SU MO TU WE TH FR SA"
370 PRINT " ---------------------"
380 REM LEADING SPACES
390 FOR I = 1 TO W
400 PRINT "   ";
410 NEXT I
420 REM PRINT DAYS
430 FOR I = 1 TO D(M)
440 IF I < 10 THEN PRINT "  ";I;
450 IF I >= 10 THEN PRINT " ";I;
460 LET W = W + 1
470 IF W = 7 THEN PRINT
480 IF W = 7 THEN LET W = 0
490 NEXT I
500 PRINT
510 END
