10 REM ** MINI TEXT ADVENTURE **
20 REM EXPLORE A DUNGEON, FIND THE GOLD
30 PRINT "** DUNGEON ADVENTURE **"
40 PRINT
50 PRINT "FIND THE GOLD AND ESCAPE!"
60 PRINT "COMMANDS: N S E W"
70 PRINT
80 LET R = 1
90 LET K = 0
100 LET G = 0
110 REM ** MAIN LOOP **
120 GOSUB 200
130 PRINT "WHAT DO YOU DO";
140 INPUT A$
150 IF A$ = "N" THEN GOSUB 300
160 IF A$ = "S" THEN GOSUB 320
170 IF A$ = "E" THEN GOSUB 340
180 IF A$ = "W" THEN GOSUB 360
190 GOTO 120
200 REM ** DESCRIBE ROOM **
210 PRINT
220 IF R = 1 THEN PRINT "ENTRANCE HALL. TORCHES FLICKER."
230 IF R = 2 THEN PRINT "DARK CORRIDOR. COLD AIR."
240 IF R = 3 THEN PRINT "ARMORY. A KEY GLINTS!"
250 IF R = 4 THEN PRINT "LOCKED VAULT."
260 IF R = 5 THEN PRINT "TREASURE ROOM! GOLD HERE!"
270 IF R = 3 THEN IF K = 0 THEN LET K = 1
280 IF R = 5 THEN IF G = 0 THEN LET G = 1
290 IF R = 1 THEN IF G = 1 THEN GOTO 380
295 RETURN
300 REM ** MOVEMENT **
310 IF R = 1 THEN LET R = 2
312 IF R = 4 THEN LET R = 5
315 RETURN
320 IF R = 2 THEN LET R = 1
322 IF R = 5 THEN LET R = 4
325 RETURN
340 IF R = 1 THEN LET R = 3
342 IF R = 2 THEN LET R = 4
344 IF R = 4 THEN IF K = 0 THEN PRINT "DOOR IS LOCKED!"
346 IF R = 4 THEN IF K = 1 THEN LET R = 5
348 RETURN
360 IF R = 3 THEN LET R = 1
362 IF R = 4 THEN LET R = 2
364 IF R = 5 THEN LET R = 4
366 RETURN
380 REM ** WIN **
390 PRINT
400 PRINT "YOU ESCAPED WITH THE GOLD!"
410 PRINT "*** YOU WIN! ***"
420 END
